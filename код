let currentCategory = [];
let currentIndex = 0;
let xp = 0;
let currentMode = 'learn';
let currentCategoryFullList = [];

function shuffle(array) {
    let m = array.length, t, i;
    while (m) {
        i = Math.floor(Math.random() * m--);
        t = array[m];
        array[m] = array[i];
        array[i] = t;
    }
    return array;
}

function addXP(amount = 10){
    xp += amount;
    document.getElementById("xp").innerText = xp;
}

function startGame(n){
    document.getElementById("menu").style.display = "none";
    document.getElementById("game").style.display = "block";
    currentCategory = shuffle([...games[n]]);
    currentCategoryFullList = [...games[n]];
    currentIndex = 0;
    changeMode('learn');
}

function changeMode(mode) {
    currentMode = mode;
    document.getElementById("modeLearn").classList.toggle("active", mode === 'learn');
    document.getElementById("modeQuiz").classList.toggle("active", mode === 'quiz');
    loadWord();
}

function loadWord(){
    if (currentCategory.length === 0) return;
    let w = currentCategory[currentIndex];
    document.getElementById("word").innerText = "🇰🇷 " + w[0];
    
    let progress = ((currentIndex) / currentCategory.length) * 100;
    document.getElementById("progressBar").style.width = progress + "%";

    if (currentMode === 'learn') {
        document.getElementById("ru").style.display = "block";
        document.getElementById("ex").style.display = "block";
        document.getElementById("quizOptions").style.display = "none";
        document.getElementById("ru").innerText = "🇷🇺 " + w[1];
        document.getElementById("ex").innerText = "💬 " + w[2];
        document.getElementById("btnNext").style.display = "inline-block";
    } else {
        document.getElementById("ru").style.display = "none";
        document.getElementById("ex").style.display = "none";
        document.getElementById("quizOptions").style.display = "grid";
        document.getElementById("btnNext").style.display = "none";
        generateQuizOptions(w[1]);
    }
    speak();
}

function generateQuizOptions(correctAnswer) {
    let optionsContainer = document.getElementById("quizOptions");
    optionsContainer.innerHTML = "";
    let wrongOptions = currentCategoryFullList.map(item => item[1]).filter(ans => ans !== correctAnswer);
    shuffle(wrongOptions);
    let chosenOptions = wrongOptions.slice(0, 3);
    chosenOptions.push(correctAnswer);
    shuffle(chosenOptions);
    
    chosenOptions.forEach(opt => {
        let btn = document.createElement("button");
        btn.className = "quiz-btn";
        btn.innerText = opt;
        btn.onclick = function() { checkAnswer(btn, opt, correctAnswer); };
        optionsContainer.appendChild(btn);
    });
}

function checkAnswer(selectedBtn, selectedAnswer, correctAnswer) {
    let buttons = document.querySelectorAll(".quiz-btn");
    buttons.forEach(btn => btn.disabled = true);
    if (selectedAnswer === correctAnswer) {
        selectedBtn.classList.add("correct");
        addXP(15);
    } else {
        selectedBtn.classList.add("wrong");
        buttons.forEach(btn => {
            if (btn.innerText === correctAnswer) btn.classList.add("correct");
        });
    }
    setTimeout(() => {
        document.getElementById("btnNext").style.display = "inline-block";
    }, 600);
}

function next(){
    currentIndex++;
    if(currentIndex >= currentCategory.length) {
        alert("🎉 Категория пройдена! Перемешиваем заново.");
        shuffle(currentCategory);
        currentIndex = 0;
    }
    loadWord();
    if (currentMode === 'learn') addXP(10);
}

function speak(){
    if ('speechSynthesis' in window) {
        window.speechSynthesis.cancel();
        let wordText = currentCategory[currentIndex][0];
        let u = new SpeechSynthesisUtterance(wordText);
        u.lang = "ko-KR";
        u.rate = 0.85;
        window.speechSynthesis.speak(u);
    }
}

function back(){
    window.speechSynthesis.cancel();
    document.getElementById("menu").style.display = "block";
    document.getElementById("game").style.display = "none";
}

// РЕГИСТРАЦИЯ SERVICE WORKER ДЛЯ РАБОТЫ ОФЛАЙН
if ('serviceWorker' in navigator) {
  window.addEventListener('load', () => {
    navigator.serviceWorker.register('sw.js')
      .then(reg => console.log('Service Worker успешно запущен', reg))
      .catch(err => console.log('Ошибка при запуске Service Worker', err));
  });
}
</script>

