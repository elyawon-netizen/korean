<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Корейский Мульт-Мир 2.0</title>

<!-- Подключаем манифест PWA для превращения в приложение -->
<link rel="manifest" href="manifest.json">
<!-- Задаем цвет панели управления в Android -->
<meta name="theme-color" content="#ffd86b">
<!-- Поддержка iOS Safari -->
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<meta name="apple-mobile-web-app-title" content="Корейский Мульт-Мир">

<style>
:root {
    --primary: #ffd86b;
    --primary-hover: #ffe49a;
    --bg-grad: linear-gradient(135deg, #a8e6ff 0%, #e2f7ff 100%);
    --card-shadow: 0 10px 25px rgba(0,0,0,0.08);
}

body {
    margin: 0;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    background: var(--bg-grad);
    min-height: 100vh;
    color: #333;
    display: flex;
    flex-direction: column;
    align-items: center;
}

#app-container {
    width: 100%;
    max-width: 600px;
    padding: 20px;
    box-sizing: border-box;
}

h1 { 
    text-align: center; 
    font-size: 28px;
    margin-bottom: 30px;
    text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
}

#menu {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
}

@media(max-width: 400px) {
    #menu { grid-template-columns: 1fr; }
}

button {
    padding: 14px 20px;
    font-size: 16px;
    font-weight: 600;
    border-radius: 16px;
    border: none;
    background: var(--primary);
    cursor: pointer;
    transition: all 0.2s ease;
    box-shadow: 0 4px 6px rgba(0,0,0,0.05);
}

button:hover { 
    background: var(--primary-hover); 
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(0,0,0,0.1);
}

button:active { transform: translateY(0); }

.game { 
    display: none; 
    text-align: center; 
}

.card {
    background: white;
    margin: 20px 0;
    padding: 30px 20px;
    border-radius: 24px;
    box-shadow: var(--card-shadow);
    position: relative;
    transition: all 0.3s ease;
}

#word {
    font-size: 36px;
    font-weight: bold;
    color: #111;
    margin-bottom: 15px;
}

.small { 
    font-size: 20px; 
    color: #444; 
    margin: 10px 0;
}

#ex {
    font-size: 16px;
    color: #666;
    background: #f7f9fa;
    padding: 10px;
    border-radius: 12px;
    margin-top: 15px;
    font-style: italic;
}

#xpBox {
    position: sticky;
    top: 10px;
    align-self: flex-end;
    background: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-weight: bold;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    z-index: 10;
    margin-bottom: 10px;
}

.controls {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    margin-top: 20px;
}

.controls button { flex: 1; }
.btn-back { background: #e0e0e0; }
.btn-back:hover { background: #eeeeee; }

.quiz-options {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    margin-top: 20px;
}
.quiz-btn {
    background: #f0f3f5;
    text-align: left;
    font-weight: normal;
}
.quiz-btn:hover { background: #e2e8f0; }
.quiz-btn.correct { background: #2ecc71 !important; color: white; }
.quiz-btn.wrong { background: #e74c3c !important; color: white; }

.progress-container {
    width: 100%;
    background: #e0e0e0;
    height: 6px;
    border-radius: 3px;
    margin-top: 15px;
    overflow: hidden;
}
.progress-bar {
    height: 100%;
    background: #4cd137;
    width: 0%;
    transition: width 0.3s ease;
}

.mode-selector {
    margin-bottom: 15px;
    display: flex;
    justify-content: center;
    gap: 10px;
}
.mode-btn {
    padding: 6px 12px;
    font-size: 14px;
    background: #fff;
    border: 2px solid var(--primary);
}
.mode-btn.active {
    background: var(--primary);
}
</style>
</head>

<body>

<div id="app-container">
    <div id="xpBox">⭐ XP: <span id="xp">0</span></div>

    <!-- МЕНЮ -->
    <div id="menu">
        <h1 style="grid-column: 1/-1; margin-top: 0;">🎮 Корейский Мульт-Мир 2.0</h1>
        <button onclick="startGame(1)">🧠 Глаголы</button>
        <button onclick="startGame(2)">🍎 Еда</button>
        <button onclick="startGame(3)">🏠 Дом</button>
        <button onclick="startGame(4)">🚗 Транспорт</button>
        <button onclick="startGame(5)">🎨 Цвета</button>
        <button onclick="startGame(6)">⏰ Время</button>
        <button onclick="startGame(7)">👨‍👩‍👧‍👦 Люди</button>
        <button onclick="startGame(8)">🌦 Погода</button>
    </div>

    <!-- ИГРОВОЙ ЭКРАН -->
    <div id="game" class="game">
        <h2 id="title" style="margin-bottom: 5px;"></h2>
        
        <div class="mode-selector">
            <button class="mode-btn active" id="modeLearn" onclick="changeMode('learn')">📖 Карточки</button>
            <button class="mode-btn" id="modeQuiz" onclick="changeMode('quiz')">🧩 Тест</button>
        </div>

        <div class="progress-container">
            <div id="progressBar" class="progress-bar"></div>
        </div>

        <div class="card">
            <div id="word"></div>
            <div id="ru" class="small"></div>
            <div id="ex" class="small"></div>
            <div id="quizOptions" class="quiz-options" style="display: none;"></div>
        </div>

        <div class="controls">
            <button class="btn-back" onclick="back()">🏠 Меню</button>
            <button id="btnSpeak" onclick="speak()">🔊 Озвучка</button>
            <button id="btnNext" onclick="next()">➡ Далее</button>
        </div>
    </div>
</div>

